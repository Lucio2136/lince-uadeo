# Copia este archivo como ".env" y pon tus API keys reales
# El archivo .env NO debe subirse a GitHub

# ── OpenAI (obligatorio) ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── LangSmith (opcional) — https://smith.langchain.com ───────────────────────
# Traza automáticamente todas las llamadas RAG/LangChain
# Crea tu proyecto en https://smith.langchain.com y pega la API key aquí
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=lince-interactivo-uadeo
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Langfuse (opcional) — https://cloud.langfuse.com ─────────────────────────
# Traza llamadas OpenAI: tokens, latencia, historial de conversaciones
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
